{
  "name": "@zasetsu/cookie-consent-manager",
  "version": "1.0.0",
  "description": "Framework-agnostic cookie consent preference collection and storage module",
  "main": "dist/cookie-consent-manager.umd.js",
  "module": "dist/cookie-consent-manager.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/cookie-consent-manager.mjs",
      "require": "./dist/cookie-consent-manager.umd.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "cookie",
    "consent",
    "gdpr",
    "kvkk",
    "cookie-banner",
    "cookie-popup",
    "cookie-consent",
    "privacy"
  ],
  "author": "Zasetsu",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/Zasetsu/cookie-consent-manager.git"
  },
  "bugs": {
    "url": "https://github.com/Zasetsu/cookie-consent-manager/issues"
  },
  "homepage": "https://github.com/Zasetsu/cookie-consent-manager#readme",
  "devDependencies": {
    "jsdom": "^29.1.0",
    "typescript": "^5.7.0",
    "vite": "^6.3.0",
    "vite-plugin-dts": "^4.5.0",
    "vitest": "^4.1.5"
  }
}
